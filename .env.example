# RTL-Gen AI Environment Variables
# Copy this file to .env and fill in your API keys

# AI Provider Keys (at least one required)
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=

# Database (optional - falls back to JSON)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rtlgenai

# Paths (optional - defaults provided)
OPENLANE_WORK=C:\tools\OpenLane
PDK_ROOT=C:\pdk
