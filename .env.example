# ============================================================================
# RTL-Gen AI Configuration
# Copy this file to .env and fill in your values
# ============================================================================

# ============================================================================
# LLM Configuration
# ============================================================================

# Anthropic API Key (get from: https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Alternative: OpenAI API Key (if using GPT instead)
# OPENAI_API_KEY=sk-your-openai-key-here

# Default LLM Model
DEFAULT_MODEL=claude-sonnet-4-20250514

# Enable Mock LLM (set to true for testing without API costs)
ENABLE_MOCK_LLM=false

# LLM Generation Parameters
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4000
LLM_TIMEOUT_SECONDS=60

# ============================================================================
# Verification Tools
# ============================================================================

# Icarus Verilog executable path (leave empty for system PATH)
IVERILOG_PATH=iverilog
VVP_PATH=vvp
GTKWAVE_PATH=gtkwave

# Simulation settings
SIMULATION_TIMEOUT=30
ENABLE_WAVEFORMS=true
WAVEFORM_FORMAT=vcd

# ============================================================================
# Caching
# ============================================================================

# Cache directory
CACHE_DIR=./cache

# Cache TTL in hours (168 = 1 week)
CACHE_TTL_HOURS=168

# Max cache size in MB
MAX_CACHE_SIZE_MB=100

# Enable automatic cache cleanup
AUTO_CLEANUP_CACHE=true

# ============================================================================
# Performance
# ============================================================================

# Enable performance monitoring
ENABLE_PERFORMANCE_MONITORING=true

# Save performance reports
SAVE_PERFORMANCE_REPORTS=true

# Max parallel workers for batch processing
MAX_BATCH_WORKERS=4

# Batch processing timeout (seconds)
BATCH_TIMEOUT_SECONDS=300

# ============================================================================
# Output Settings
# ============================================================================

# Default output directory
OUTPUT_DIR=./outputs

# File organization
ORGANIZE_BY_DATE=true
CREATE_README=true

# ============================================================================
# Testbench Generation
# ============================================================================

# Exhaustive test threshold (max input bits for exhaustive testing)
EXHAUSTIVE_THRESHOLD=16

# Random test count (when exhaustive testing not feasible)
RANDOM_TEST_COUNT=100

# Enable corner case tests
ENABLE_CORNER_TESTS=true

# Clock period for sequential circuits (ns)
DEFAULT_CLOCK_PERIOD=10

# Reset duration (clock cycles)
DEFAULT_RESET_CYCLES=2

# ============================================================================
# Logging
# ============================================================================

# Debug mode (verbose output)
DEBUG_MODE=false

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file location
LOG_FILE=./logs/rtl_gen_ai.log

# Enable console output
ENABLE_CONSOLE_LOG=true

# ============================================================================
# Web UI (Streamlit)
# ============================================================================

# Streamlit server settings
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# Enable browser auto-open
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false

# ============================================================================
# Security
# ============================================================================

# Enable input validation
ENABLE_INPUT_VALIDATION=true

# Max input length (characters)
MAX_INPUT_LENGTH=5000

# Enable rate limiting
ENABLE_RATE_LIMITING=false

# Rate limit (requests per hour)
RATE_LIMIT_PER_HOUR=100

# ============================================================================
# Advanced Settings
# ============================================================================

# Enable experimental features
ENABLE_EXPERIMENTAL=false

# Custom prompt templates directory
CUSTOM_TEMPLATES_DIR=./templates

# Training data directory (for future fine-tuning)
TRAINING_DATA_DIR=./training_data

# ============================================================================
# Database (if using external database)
# ============================================================================

# Database type (sqlite, postgresql)
DATABASE_TYPE=sqlite

# SQLite database path
SQLITE_DB_PATH=./cache/rtl_gen_ai.db

# PostgreSQL connection (if using PostgreSQL)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=rtl_gen_ai
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your_password

# ============================================================================
# Cloud Storage (optional)
# ============================================================================

# Enable cloud backup
ENABLE_CLOUD_BACKUP=false

# AWS S3 settings
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_S3_BUCKET=rtl-gen-ai-backup
# AWS_REGION=us-east-1

# ============================================================================
# Monitoring & Analytics
# ============================================================================

# Enable usage analytics
ENABLE_ANALYTICS=false

# Analytics endpoint
# ANALYTICS_ENDPOINT=https://analytics.example.com

# Sentry DSN (for error tracking)
# SENTRY_DSN=https://your-sentry-dsn

# ============================================================================
# End of Configuration
# ============================================================================
