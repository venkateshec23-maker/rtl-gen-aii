# RTL-Gen AI Environment Variables
# Copy this to .env and fill in your keys

# LLM API Keys (at least one required)
ANTHROPIC_API_KEY=your_claude_key_here
GOOGLE_API_KEY=your_gemini_key_here
GROQ_API_KEY=your_groq_key_here

# Database (auto-configured in Codespaces)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rtlgenai

# EDA Tool Paths (auto-configured)
OPENLANE_WORK=/workspaces/rtl-gen-aii/openlane_work
PDK_ROOT=/workspaces/rtl-gen-aii/pdk
