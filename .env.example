# RTL-Gen AI Environment Variables
# Copy this to .env and fill in your keys

# LLM API Keys (at least one required)
ANTHROPIC_API_KEY=your_claude_key_here
GOOGLE_API_KEY=your_gemini_key_here
GROQ_API_KEY=your_groq_key_here
OPENROUTER_API_KEY=your_openrouter_key_here

# Error Tracking (optional — free tier at sentry.io)
SENTRY_DSN=

# Database (auto-configured in Codespaces; free tier at supabase.com or neon.tech)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rtlgenai

# Redis (optional — free tier at upstash.com)
REDIS_URL=redis://localhost:6379/0

# EDA Tool Paths (auto-configured)
OPENLANE_WORK=/workspaces/rtl-gen-aii/openlane_work
PDK_ROOT=/workspaces/rtl-gen-aii/pdk

# Streamlit Cloud mode (set to 1 when deploying)
STREAMLIT_CLOUD=0
