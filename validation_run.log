read_verilog /work/design_syn.v

# Floorplan core area
init_floorplan -site sky130_fd_sc_hd \
    -core_width ${core_width} \
    -core_height ${core_height} \
    -margin_x 10 -margin_y 10

# I/O Pin Placement
# I/O Pin Placement

place_pin wire -side RIGHT -location 91.3 20.0
place_pin wire -side RIGHT -location 91.3 30.4
place_pin wire -side RIGHT -location 91.3 40.9
place_pin reg -side RIGHT -location 91.3 51.3


# Power Grid Generation
# Power Grid Generation
# ========================

# Layer definitions
set_layer VDD {
  layer metal1
  layer metal4
  layer metal5
}

set_layer VSS {
  layer metal1
  layer metal4
  layer metal5
}

# Core power ring
add_ring {
  name   power_ring
  layer  {metal5 metal4 metal4 metal4}
  width  4.0
  spacing 0 0
  core 2.0 2.0 69.3416661799634 69.3416661799634
  vdd VDD
  gnd VSS
}

# Metal1 cell rail configuration
add_rails {
  layer metal1
  vdd {name VDD}
  gnd {name VSS}
  spacing 10.0
  width 1.0
}

# Metal4 vertical stripes
add_straps {
  layer metal4
  direction vertical
  spacing 100.0
  width 4.0
  offset 10
  vdd VDD
  gnd VSS
}

# Metal5 horizontal stripes
add_straps {
  layer metal5
  direction horizontal
  spacing 100.0
  width 4.0
  offset 10
  vdd VDD
  gnd VSS
}

# Via connectivity
connect {
  metal1 metal4 via1
  metal4 metal5 via4
}


# Run power grid generation
pdngen


# Export
write_def /work/floorplan.def

# Report
report_placement -verbose


