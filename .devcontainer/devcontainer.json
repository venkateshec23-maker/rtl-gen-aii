{
  "name": "RTL-Gen AI Development",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",

  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "enableNonRootDocker": true
    }
  },

  "forwardPorts": [8501, 8502, 5432],

  "portsAttributes": {
    "8501": {
      "label": "Streamlit UI",
      "onAutoForward": "openPreview"
    },
    "8502": {
      "label": "REST API",
      "onAutoForward": "notify"
    },
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "silent"
    }
  },

  "postCreateCommand": "bash .devcontainer/setup.sh",

  "secrets": {
    "ANTHROPIC_API_KEY": {
      "description": "Claude API key"
    },
    "GOOGLE_API_KEY": {
      "description": "Gemini API key"
    },
    "GROQ_API_KEY": {
      "description": "Groq API key"
    }
  },

  "remoteEnv": {
    "OPENLANE_WORK": "/workspaces/rtl-gen-aii/openlane_work",
    "PDK_ROOT": "/workspaces/rtl-gen-aii/pdk",
    "DATABASE_URL": "postgresql://postgres:postgres@localhost:5432/rtlgenai"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "eamodio.gitlens"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.linting.enabled": true,
        "editor.formatOnSave": true
      }
    }
  }
}
