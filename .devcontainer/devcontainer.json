{
    "name": "RTL-Gen AI",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2": {
            "version": "latest",
            "enableNonRootDocker": "true"
        }
    },
    "postCreateCommand": "bash .devcontainer/setup.sh",
    "postStartCommand": "nohup streamlit run app.py --server.port 8501 --server.headless true &",
    "forwardPorts": [8501, 4096],
    "portsAttributes": {
        "8501": {
            "label": "RTL-Gen AI Dashboard",
            "onAutoForward": "openBrowser",
            "protocol": "http"
        },
        "4096": {
            "label": "OpenCode ACP",
            "onAutoForward": "silent"
        }
    },
    "secrets": {
        "ANTHROPIC_API_KEY": {
            "description": "Claude API key",
            "documentationUrl": "https://console.anthropic.com"
        },
        "GROQ_API_KEY": {
            "description": "Groq API key (free tier, no credit card)",
            "documentationUrl": "https://console.groq.com"
        },
        "GEMINI_API_KEY": {
            "description": "Google Gemini API key",
            "documentationUrl": "https://aistudio.google.com/apikey"
        }
    },
    "remoteEnv": {
        "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
        "GROQ_API_KEY": "${localEnv:GROQ_API_KEY}",
        "GEMINI_API_KEY": "${localEnv:GEMINI_API_KEY}",
        "OPENLANE_WORK": "/workspaces/rtl-gen-aii/openroad",
        "PDK_ROOT": "/workspaces/rtl-gen-aii/pdk"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "mfraha.verilog-language-features",
                "streetsidesoftware.code-spell-checker"
            ]
        }
    }
}
