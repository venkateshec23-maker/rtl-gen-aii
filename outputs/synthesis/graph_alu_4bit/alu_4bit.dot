digraph alu_4bit {
    rankdir=LR;
    splines=ortho;
    
    // Input nodes
    node [shape=box, style=filled, color=lightblue];
    in0 [label="in0"];
    in1 [label="in1"];

    // Gates
    node [shape=circle, style=filled, color=lightgreen];
    g0 [label="G0"];
    g1 [label="G1"];
    g2 [label="G2"];
    g3 [label="G3"];
    g4 [label="G4"];

    // Flip-flops
    node [shape=box, style=filled, color=lightyellow];

    // Outputs
    node [shape=box, style=filled, color=lightpink];
    out0 [label="out0"];
    out1 [label="out1"];

    // Connections
    in0 -> g0;
    g0 -> out0;
    in1 -> g1;
    g1 -> out1;
    in0 -> g2;
    g2 -> out0;
    in1 -> g3;
    g3 -> out1;
    in0 -> g4;
    g4 -> out0;
}
