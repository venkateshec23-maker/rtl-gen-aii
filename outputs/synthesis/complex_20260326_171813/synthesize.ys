# Yosys synthesis script for complex
# Generated by RTL-Gen AI at 2026-03-26 17:18:13

# Read design
read_verilog outputs\synthesis\complex_20260326_171813\complex.v

# Elaborate design
hierarchy -check -top complex

# Show design structure
proc; opt; show -prefix outputs\synthesis\complex_20260326_171813\complex_struct -format dot

# Technology mapping
techmap; opt

# For ASIC synthesis
if { asic == "asic" }
    # Map to standard cells
    dfflibmap -liberty /usr/local/share/yosys/asic_cells.lib
    abc -liberty /usr/local/share/yosys/asic_cells.lib
else
    # For FPGA synthesis
    synth -top complex
endif

# Statistics
stat -tech asic > outputs\synthesis\complex_20260326_171813/synthesis_stats.txt

# Write netlist
write_verilog outputs\synthesis\complex_20260326_171813/complex_netlist.v

# Write JSON for reporting
write_json outputs\synthesis\complex_20260326_171813/synthesis_report.json

# Show final design
show -prefix outputs\synthesis\complex_20260326_171813\complex_final -format dot
